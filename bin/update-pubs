#!/usr/bin/env bash
#
# One-command Google Scholar -> _bibliography/papers.bib updater.
#
# The FIRST run builds an isolated Python environment in ./.venv and installs
# the dependencies. Every later run just reuses it — no pip/venv fuss.
#
#   bin/update-pubs --dry-run     # preview what would be added (writes nothing)
#   bin/update-pubs               # append new papers as stubs to papers.bib
#   bin/update-pubs --id XXXX     # use a different Scholar id
#
# To rebuild the environment from scratch:  rm -rf .venv  (then run again)
#
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV="$ROOT/.venv"
PY="$VENV/bin/python"

if [ ! -x "$PY" ]; then
  echo "First run: creating isolated environment in .venv (one-time, needs internet)…"
  python3 -m venv "$VENV"
  "$PY" -m pip install --quiet --upgrade pip
  "$PY" -m pip install -r "$ROOT/scripts/requirements.txt"
  echo "Environment ready."
  echo
fi

exec "$PY" "$ROOT/scripts/update_publications.py" "$@"
